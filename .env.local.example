# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Platform
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_DOMAIN=

# Multi-Tenant: default tenant slug for local dev / single-tenant fallback
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=yesilcam-cekmekoy

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@cafepanel.com
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# SMS Provider: mock | netgsm | twilio
SMS_PROVIDER=mock

# Netgsm (if SMS_PROVIDER=netgsm)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=

# Twilio (if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
